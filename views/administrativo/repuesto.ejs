<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proformas</title>
    
    <link rel="stylesheet" type="text/css" href="/stylesheets/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="/stylesheets/DataTables/datatables.min.css"/>
    <link rel="stylesheet" type="text/css" href="/stylesheets/dashboard.css">
    <link rel="stylesheet" type="text/css" href="/stylesheets/comun.css">
    <link rel="stylesheet" type="text/css" href="/stylesheets/icons/adminLTE-2.4.15/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="/stylesheets/icons/bootstrap-5.1/bootstrap-icons.css">
    
</head>
<body>
    <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow mb-3">
        <div class="navbar-brand col-md-3 col-lg-2 me-0 px-3">Men&uacute;</div>
        <button class="navbar-toggler position-absolute d-md-none collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <input class="form-control bg-dark w-100" type="text" aria-label="Search" disabled>
        <div class="btn-group">
          <button type="button" class="btn btn-secondary dropdown-toggle rounded-pill" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false">
            Opciones
          </button>
          <ul class="dropdown-menu dropdown-menu-lg-end">
            <li><a class="dropdown-item" href="/logout"><i class="fa fa-power-off"></i> Cerrar sesi&oacute;n</a></li>
            <li><button id="cambiar_password" class="dropdown-item"><i class="fa fa-unlock-alt"></i> Cambiar contase&ntilde;a</button></li>
            <li><a class="dropdown-item" href="#">Menu item</a></li>
          </ul>
        </div>
    </header>
    
    <div class="container-fluid">
        <div class="row">
          <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse" style="background-color: rgb(230,230,230);">
            <div class="position-sticky pt-3">
              <ul class="nav flex-column">
                <li class="nav-item">
                  <a class="nav-link" aria-current="page" href="./reclamo">
                    <i class="fa fa-exclamation-triangle"></i>
                    Reclamos
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="./usuario">
                    <i class="fa fa-users"></i>
                    Usuarios
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="./tecnico">
                    <i class="fa fa-user"></i>
                    T&eacute;cnicos
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="./producto">
                    <i class="fa fa-shopping-cart"></i>
                    Productos
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link active" href="./repuesto">
                    <i class="fa fa-cogs"></i>
                    Repuestos
                  </a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="./planilla">
                    <i class="fa fa-table"></i>
                    Planillas
                  </a>
                </li>
              </ul>
            </div>
          </nav>
                  
          <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">

            <div class="d-grid gap-2 d-md-flex justify-content-md-between">
              <div>
                <div class="btn-group">
                  <button id="btn_actualizar" class="btn btn-outline-dark me-md-2 rounded-pill" title="Actualizar" type="button">
                    <span id="span_actualizar" class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                    <i class="fa fa-refresh"></i>
                  </button>
                </div>
              </div>
              <div>
                <div class="btn-group">
                  <button id="btn_nuevo_producto" class="btn btn-outline-primary me-md-2 rounded-pill" title="Nuevo Producto" type="button">
                      <span class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                      <i class="fa fa-plus-circle"></i>
                      Aceptar
                  </button>
                  <button id="btn_archivar_repuesto" class="btn btn-outline-primary me-md-2 rounded-pill" title="Eliminar producto" type="button">
                      <span class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                      <i class="fa fa-folder-open"></i>
                      Archivar
                  </button>
                </div>
              </div>
          </div>
      
            <h2>Repuestos</h2>
            <div class="table-responsive">
              <table id="tbl_repuesto" class="table table-hover table-sm table-bordered text-dark">
                <thead class="thead-light">
                  <tr>
                    <th scope="col">ID</th>
                    <th scope="col">N&deg; de orden</th>
                    <th scope="col">T&eacute;cnico</th>
                    <th scope="col">Localidad t&eacute;cnico</th>
                    <th scope="col">Cliente</th>
                    <th scope="col">Tel&eacute;fono cliente</th>
                    <th scope="col">Producto</th>
                    <th scope="col">Repuesto</th>
                    <th scope="col">Observaci&oacute;n</th>
                  </tr>
                </thead>
                <tbody>
                </tbody>
              </table>
            </div><br>

            <div class="d-grid gap-2 d-md-flex justify-content-md-between">
              <div>
                <div class="btn-group">
                  <button id="btn_actualizar_archivado" class="btn btn-outline-dark me-md-2 rounded-pill" title="Actualizar" type="button">
                    <span id="span_actualizar_archivado" class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                    <i class="fa fa-refresh"></i>
                  </button>
                </div>
              </div>
              <div>
                <div class="btn-group">
                  <button id="btn_desarchivar_repuesto" class="btn btn-outline-primary me-md-2 rounded-pill" title="Eliminar producto" type="button">
                      <span class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                      <i class="fa fa-folder"></i>
                      Desarchivar
                  </button>
                </div>
              </div>
          </div>
      
            <h2>Repuestos archivados</h2>
            <div class="table-responsive">
              <table id="tbl_repuesto_archivado" class="table table-hover table-sm table-bordered text-dark">
                <thead class="thead-light">
                  <tr>
                    <th scope="col">ID</th>
                    <th scope="col">N&deg; de orden</th>
                    <th scope="col">T&eacute;cnico</th>
                    <th scope="col">Localidad t&eacute;cnico</th>
                    <th scope="col">Cliente</th>
                    <th scope="col">Tel&eacute;fono cliente</th>
                    <th scope="col">Producto</th>
                    <th scope="col">Repuesto</th>
                    <th scope="col">Observaci&oacute;n</th>
                    <th scope="col">Fecha y hora archivado</th>
                  </tr>
                </thead>
                <tbody>
                </tbody>
              </table>
            </div>

          </main>
        </div>
      </div>

      <div class="modal fade" id="divFormularioRepuesto" tabindex="-1" aria-labelledby="tituloFormulario" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="tituloFormulario">Nuevo producto</h5>
              <button type="button" class="btn-close btn-outline-danger rounded-pill" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <form id="formularioProducto" novalidate>
                <div class="mb-3 row">
                  <label for="descripcion" class="col-sm-2 col-form-label">Descripci&oacute;n</label>
                  <div class="col-sm-10">
                    <input type="text" class="form-control" id="descripcion" required>
                    <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                  </div>
                </div><hr>
                <div class="mb-3 row">
                  <label for="marca" class="col-sm-2 col-form-label">Marca</label>
                  <div class="col-sm-10">
                    <input type="text" class="form-control" id="marca" required>
                    <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                  </div>
                </div><hr>
                <div class="mb-3 row">
                  <label for="modelo" class="col-sm-2 col-form-label">Modelo</label>
                  <div class="col-sm-10">
                    <input type="text" class="form-control" id="modelo" required>
                    <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                  </div>
                </div><hr>
                <div class="mb-3 row">
                  <label for="numeroSerie" class="col-sm-2 col-form-label">N&uacute;mero de serie</label>
                  <div class="col-sm-10">
                    <input type="number" class="form-control" id="numeroSerie" required>
                    <div class="invalid-feedback">Ingrese un valor v&aacute;lido (solo n&uacute;meros).</div>
                  </div>
                </div>
              </form>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-danger rounded-pill" data-bs-dismiss="modal"><i class="fa fa-ban"></i> Cancelar</button>
              <button type="button" id="btn_guardar" class="btn btn-outline-primary rounded-pill"><i class="fa fa-paper-plane-o"></i> Guardar</button>
            </div>
          </div>
        </div>
      </div>

    <script type="text/javascript" src="/javascripts/jquery.min.js"></script>
    <script type="text/javascript" src="/javascripts/datatables.min.js"></script>
    <script type="text/javascript" src="/javascripts/bootstrap.bundle.min.js"></script>
    <script type="text/javascript" src="/javascripts/sweetalert2@11.js"></script>
    <script type="text/javascript" src="/javascripts/errors.js"></script>
    <script type="text/javascript" src="/javascripts/comun.js"></script>
    <script type="text/javascript" src="/javascripts/ajax.js"></script>
    <script type="text/javascript" src="/javascripts/administrativo/repuesto.js"></script>
</body>
</html>