      <link rel="stylesheet" type="text/css" href="/stylesheets/bootstrap.min.css">
      <link rel="stylesheet" type="text/css" href="/stylesheets/DataTables/datatables.min.css"/>
      <link rel="stylesheet" type="text/css" href="/stylesheets/dashboard.css">
      <link rel="stylesheet" type="text/css" href="/stylesheets/comun.css">
      <link rel="stylesheet" type="text/css" href="/stylesheets/icons/adminLTE-2.4.15/font-awesome.min.css">
      <link rel="stylesheet" type="text/css" href="/stylesheets/icons/bootstrap-5.1/bootstrap-icons.css">
      
  </head>
  <body>
      <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow mb-3">
          <div class="navbar-brand col-md-3 col-lg-2 me-0 px-3">Men&uacute;</div>
          <button class="navbar-toggler position-absolute d-md-none collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
              <span class="navbar-toggler-icon"></span>
          </button>
          <input class="form-control bg-dark w-100" type="text" aria-label="Search" disabled>
          <div class="btn-group">
            <button type="button" class="btn btn-secondary dropdown-toggle rounded-pill" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false">
              Opciones
            </button>
            <ul class="dropdown-menu dropdown-menu-lg-end">
              <li><a class="dropdown-item" href="/logout"><i class="fa fa-power-off"></i> Cerrar sesi&oacute;n</a></li>
              <li><button id="cambiar_password" class="dropdown-item"><i class="fa fa-unlock-alt"></i> Cambiar contase&ntilde;a</button></li>
              <li><a class="dropdown-item" href="#">Menu item</a></li>
            </ul>
          </div>
      </header>
      
      <div class="container-fluid">
          <div class="row">
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse" style="background-color: rgb(230,230,230);">
              <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                  <li class="nav-item">
                    <a class="nav-link" href="./reclamo">
                      <i class="fa fa-exclamation-triangle"></i>
                      Reclamos
                    </a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link" href="./usuario">
                      <i class="fa fa-users"></i>
                      Usuarios
                    </a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link active" href="./tecnico">
                      <i class="fa fa-user"></i>
                      T&eacute;cnicos
                    </a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link" href="./producto">
                      <i class="fa fa-shopping-cart"></i>
                      Productos
                    </a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link" href="./repuesto">
                      <i class="fa fa-cogs"></i>
                      Repuestos
                    </a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link" href="./planilla">
                      <i class="fa fa-table"></i>
                      Planillas
                    </a>
                  </li>
                </ul>
              </div>
            </nav>
                    
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">

              <div class="d-grid gap-2 d-md-flex justify-content-md-between">
                <div>
                  <div class="btn-group">
                    <button id="btn_actualizar" class="btn btn-outline-dark me-md-2 rounded-pill" title="Actualizar" type="button">
                      <span id="span_actualizar" class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                      <i class="fa fa-refresh"></i>
                    </button>
                  </div>
                </div>
                <div>
                  <div class="btn-group">
                    <button id="btn_nuevo_tecnico" class="btn btn-outline-primary me-md-2 rounded-pill" title="Nuevo t&eacute;cnico" type="button">
                        <span class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                        <i class="fa fa-user-plus"></i>
                        <span id="span_nuevo_tecnico" class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                        Nuevo
                    </button>
                    <button id="btn_editar_tecnico" class="btn btn-outline-primary me-md-2 rounded-pill" title="Editar t&eacute;cnico" type="button">
                        <span class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                        <i class="fa fa-pencil"></i>
                        <span id="span_editar_tecnico" class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                        Editar
                    </button>
                    <button id="btn_archivar_tecnico" class="btn btn-outline-primary me-md-2 rounded-pill" title="Archivar t&eacute;cnico" type="button">
                        <span class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                        <i class="fa fa-folder-open"></i>
                        Archivar
                    </button>
                  </div> 
                </div>
            </div>
        
              <h2>T&eacute;cnicos</h2>
              <div class="table-responsive">
                <table id="tbl_tecnico" class="table table-hover table-sm table-bordered text-dark">
                  <thead class="thead-light">
                    <tr>
                      <th scope="col">ID</th>
                      <th scope="col">N&deg; legajo</th>
                      <th scope="col">Apellido</th>
                      <th scope="col">Nombre</th>
                      <th scope="col">D.N.I.</th>
                      <th scope="col">Nombre de usuario</th>
                      <th scope="col">Tel&eacute;fono</th>
                      <th scope="col">Email</th>
                      <th scope="col">Localidad</th>
                      <th scope="col">Provincia</th>
                      <th scope="col">Direcci&oacute;n</th>
                      <th scope="col">CBU/CVU</th>
                      <th scope="col">Nombre de servicio</th>
                      <th scope="col">Hrs. desde</th>
                      <th scope="col">Hrs. hasta</th>
                    </tr>
                  </thead>
                  <tbody>
                  </tbody>
                </table>
              </div><br>
              <div class="d-grid gap-2 d-md-flex justify-content-md-between">
                <div>
                  <div class="btn-group">
                    <button id="btn_actualizar_archivado" class="btn btn-outline-dark me-md-2 rounded-pill" title="Actualizar" type="button">
                      <span id="spam_actualizar_archivado" class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                      <i class="fa fa-refresh"></i>
                    </button>
                  </div>
                </div>
                <div>
                  <div class="btn-group">
                    <button id="btn_desarchivar_tecnico" class="btn btn-outline-primary me-md-2 rounded-pill" title="Desarchivar t&eacute;cnico" type="button">
                        <span class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                        <i class="fa fa-folder"></i>
                        Desarchivar
                    </button>
                  </div> 
                </div>
            </div>
        
              <h2>T&eacute;cnicos archivados</h2>
              <div class="table-responsive">
                <table id="tbl_tecnico_archivado" class="table table-hover table-sm table-bordered text-dark">
                  <thead class="thead-light">
                    <tr>
                      <th scope="col">ID</th>
                      <th scope="col">N&deg; legajo</th>
                      <th scope="col">Apellido</th>
                      <th scope="col">Nombre</th>
                      <th scope="col">D.N.I.</th>
                      <th scope="col">Nombre de usuario</th>
                      <th scope="col">Tel&eacute;fono</th>
                      <th scope="col">Email</th>
                      <th scope="col">Localidad</th>
                      <th scope="col">Provincia</th>
                      <th scope="col">Direcci&oacute;n</th>
                      <th scope="col">CBU/CVU</th>
                      <th scope="col">Nombre de servicio</th>
                      <th scope="col">Hrs. desde</th>
                      <th scope="col">Hrs. hasta</th>
                      <th scope="col">Fecha archivado</th>
                    </tr>
                  </thead>
                  <tbody>
                  </tbody>
                </table>
              </div>                        
            </main>
          </div>
        </div>

        <div class="modal fade" id="divFormularioTecnico" tabindex="-1" aria-labelledby="tituloFormulario" aria-hidden="true">
          <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="tituloFormulario">Nuevo t&eacute;cnico</h5>
                <button type="button" class="btn-close btn-outline-danger rounded-pill" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <form id="formularioTecnico" novalidate>
                  <div class="mb-3 row">
                    <label for="selectUsuario" class="col-sm-2 col-form-label">Usuarios</label>
                    <div class="col-sm-10">
                      <select class="form-select text-capitalize" id="selectUsuario" required>
                        <option value="">Asignar usuario...</option>
                      </select>
                      <div class="invalid-feedback">Seleccione una opci&oacute;n.</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="user" class="col-sm-2 col-form-label">Nombre usuario</label>
                    <div class="col-sm-10">
                      <input type="text" class="form-control" id="user" disabled>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="dni" class="col-sm-2 col-form-label">D.N.I.</label>
                    <div class="col-sm-10">
                      <input type="number" class="form-control" id="dni" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido (solo n&uacute;meros).</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="telefono" class="col-sm-2 col-form-label">Tel&eacute;fono</label>
                    <div class="col-sm-10">
                      <input type="number" class="form-control" id="telefono" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido (solo n&uacute;meros).</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="provincia" class="col-sm-2 col-form-label">Provincia</label>
                    <div class="col-sm-10">
                      <input type="text" class="form-control" id="provincia" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="localidad" class="col-sm-2 col-form-label">Localidad</label>
                    <div class="col-sm-10">
                      <input type="text" class="form-control" id="localidad" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="direccion" class="col-sm-2 col-form-label">Direcci&oacute;n</label>
                    <div class="col-sm-10">
                      <input type="text" class="form-control" id="direccion" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="cbu" class="col-sm-2 col-form-label">CBU/CVU</label>
                    <div class="col-sm-10">
                      <input type="number" class="form-control" id="cbu" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido (solo n&uacute;meros).</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="serviceNombre" class="col-sm-2 col-form-label">Nombre servicio</label>
                    <div class="col-sm-10">
                      <input type="text" class="form-control" id="serviceNombre" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="horarioDesde" class="col-sm-2 col-form-label">Horario desde</label>
                    <div class="col-sm-10">
                      <input type="time" class="form-control" id="horarioDesde" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                    </div>
                  </div><hr>
                  <div class="mb-3 row">
                    <label for="horarioHasta" class="col-sm-2 col-form-label">Horario hasta</label>
                    <div class="col-sm-10">
                      <input type="time" class="form-control" id="horarioHasta" required>
                      <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
                    </div>
                  </div>
                </form>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger rounded-pill" data-bs-dismiss="modal"><i class="fa fa-ban"></i> Cancelar</button>
                <button type="button" id="btn_guardar" class="btn btn-outline-primary rounded-pill">
                  <i class="fa fa-paper-plane-o"></i>
                  <span id="span_guardar" class="spinner-border spinner-border-sm visually-hidden" role="status" aria-hidden="true"></span>
                  Guardar
                </button>
              </div>
            </div>
          </div>
        </div>

      <script type="text/javascript" src="/javascripts/jquery.min.js"></script>
      <script type="text/javascript" src="/javascripts/datatables.min.js"></script>
      <script type="text/javascript" src="/javascripts/bootstrap.bundle.min.js"></script>
      <script type="text/javascript" src="/javascripts/sweetalert2@11.js"></script>
      <script type="text/javascript" src="/javascripts/comun.js"></script>
      <script type="text/javascript" src="/javascripts/ajax.js"></script>
      <script type="text/javascript" src="/javascripts/administrativo/tecnico.js"></script>
  </body>
</html>