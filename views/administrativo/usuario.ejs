                    </select>
                    <div class="invalid-feedback">Seleccione una opci&oacute;n.</div>
                  </div>
                </div><hr>
                <div class="mb-3 row">
                  <label for="passwordInsertar" class="col-sm-2 col-form-label">Contrase&ntilde;a</label>
                  <div class="col-sm-10">
                    <input type="password" class="form-control" id="passwordInsertar" required>
                    <div class="invalid-feedback">Ingrese un valor v&aacute;lido.</div>
